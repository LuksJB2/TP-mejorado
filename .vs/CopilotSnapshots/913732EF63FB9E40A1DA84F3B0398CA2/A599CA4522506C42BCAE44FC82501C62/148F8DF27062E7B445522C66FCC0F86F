        public PuestoControl(double pr1, double pr2, double pr3, double pr4)
        {
            precioCat1 = pr1;
            precioCat2 = pr2;
            precioCat3 = pr3;
            precioCat4 = pr4;
            ticket = new Ticket[100];
            cantidadTickets = 0;
